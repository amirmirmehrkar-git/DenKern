# Local / temporary fetch artifacts
chatgpt-share-*.html

# Archive
archive/

# Obsidian local workspace state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/

# OS/editor noise
.DS_Store
Thumbs.db

# Node / monorepo
node_modules/
.turbo/
.next/
dist/
build/
*.tsbuildinfo

# Env files
.env
.env.local
.env*.local

# Editor
.vscode/settings.json.bak

# Cursor IDE — local rules, not shared project config
.cursor/

# Next.js auto-generated — must not be committed (re-created by next dev/build)
apps/web/next-env.d.ts

# Temp / scratch scripts — naming convention: _tmp-*.mjs
scripts/_tmp-*.mjs

# Lockfiles — only the root package-lock.json is canonical.
# Do not commit nested lockfiles created by running npm install inside packages/.
packages/*/package-lock.json
apps/*/package-lock.json

# ML model artifacts — never commit binary model files
*.pt
*.pth
*.ckpt
*.onnx
prediction/artifacts/
contracts/prediction/artifacts/
packages/prediction-adapter/models/
