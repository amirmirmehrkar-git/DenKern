{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@denkkern/types": ["../../packages/types/src/index.ts"],
      "@denkkern/engine": ["../../packages/engine/src/index.ts"],
      "@denkkern/mock": ["../../mock/index.ts"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["src", "next.config.js", "next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
